# ── Agent wallet (server-side ONLY — never expose to the frontend) ──────────────
# Funds 0G Compute, pays gas for on-chain commits, and IS the agent's identity.
PRIVATE_KEY=0x...

# ── 0G Chain (Galileo testnet first, mainnet for the final lock) ────────────────
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602

# Deployed registry contract (filled in after `forge create`)
ORACLE_CONTRACT_ADDRESS=0x...

# Deployed Prediction iNFT contract (soulbound ERC-721, minted per prediction)
INFT_CONTRACT_ADDRESS=0x...

# ── 0G Compute (Direct path) ────────────────────────────────────────────────────
# Provider address to route inference to. Discover with the probe script
# (broker.inference.listService) and paste the one you want here.
COMPUTE_PROVIDER_ADDRESS=0x...
# Minimum ledger balance (in OG) before the agent tops itself up.
LEDGER_MIN_BALANCE=1
LEDGER_TOPUP_AMOUNT=1
LEDGER_INIT_AMOUNT=3

# ── 0G Storage ──────────────────────────────────────────────────────────────────
OG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# ── Football data feed ──────────────────────────────────────────────────────────
FOOTBALL_API_BASE=https://api.football-data.org/v4
FOOTBALL_API_KEY=
# Competition code (football-data.org). WC = FIFA World Cup. With no API key the
# agent falls back to data/fixtures.json (predict) and data/results.json (resolve).
FOOTBALL_COMPETITION=WC

# ── X / social (optional for group stage, required for the brand engine) ────────
# OAuth 1.0a user context. Leave all four blank to run in dry-run mode (the agent
# prints the tweet it WOULD post instead of posting). Get these from the X
# developer portal: an app with Read+Write, plus user access token & secret.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Public scoreboard URL used in the "verify it yourself" tweet links.
FRONTEND_URL=http://localhost:8099
